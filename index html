<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Lab Scope PRO</title>
    <link rel="manifest" href="manifest.json">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/base.css">
    <link rel="stylesheet" href="css/header.css">
    <link rel="stylesheet" href="css/tabs.css">
    <link rel="stylesheet" href="css/measurements.css">
    <link rel="stylesheet" href="css/canvas.css">
    <link rel="stylesheet" href="css/controls.css">
    <link rel="stylesheet" href="css/menu.css">
    <link rel="stylesheet" href="css/splash.css">
    <link rel="stylesheet" href="css/simulator.css">
    <link rel="stylesheet" href="css/simset.css">
</head>
<body>

<!-- HEADER -->
<div id="header">
    <button id="hamburgerBtn" onclick="UI.toggleMenu()">☰</button>
    <div class="logo">
        <span class="logo-lab">LAB</span><span class="logo-scope">SCOPE</span><span class="logo-pro">PRO</span>
    </div>
    <div class="header-right">
        <span id="sigTypeBadge" class="sig-badge">---</span>
        <span id="statusTxt" class="status-label">STANDBY</span>
        <div id="statusDot" class="status-dot"></div>
    </div>
</div>

<!-- MAIN TABS -->
<div id="tabs">
    <div class="tab active" data-tab="osc"  onclick="UI.switchTab('osc')">OSC</div>
    <div class="tab"        data-tab="fft"  onclick="UI.switchTab('fft')">OSC+FFT</div>
    <div class="tab"        data-tab="info" onclick="UI.switchTab('info')">OSC+INFO</div>
    <div class="tab"        data-tab="sim"  onclick="UI.switchTab('sim')">SIM</div>
</div>

<!-- MEASUREMENTS BAR -->
<div id="measurements">
    <div class="meas"><span class="meas-label">FREQ</span><span class="meas-value" id="mFreq">---</span></div>
    <div class="meas"><span class="meas-label">Vpp</span> <span class="meas-value" id="mVpp">---</span></div>
    <div class="meas"><span class="meas-label">RMS</span> <span class="meas-value" id="mRms">---</span></div>
    <div class="meas"><span class="meas-label">dBFS</span><span class="meas-value" id="mDb">---</span></div>
</div>

<!-- OSC VIEW PILLS (non-SIM tabs in SIM mode) -->
<div id="oscPills">
    <div class="ch-pill ch-pill-1 active" id="oscPill1" onclick="UI.setOscView('ch1')"><div class="ch-dot"></div> CH1</div>
    <div class="ch-pill ch-pill-2"        id="oscPill2" onclick="UI.setOscView('ch2')"><div class="ch-dot"></div> CH2</div>
    <div class="ch-pill ch-pill-3"        id="oscPill3" onclick="UI.setOscView('ch3')"><div class="ch-dot"></div> CH3</div>
    <button class="btn-exit-sim" onclick="UI.exitSimMode()">✕ EXIT SIM</button>
</div>

<!-- SIM CHANNEL PILLS -->
<div id="chPills">
    <div class="ch-pill ch-pill-1" id="pill1" onclick="UI.toggleChannel(1)"><div class="ch-dot"></div> CH1</div>
    <div class="ch-pill ch-pill-2" id="pill2" onclick="UI.toggleChannel(2)"><div class="ch-dot"></div> CH2</div>
    <div class="ch-pill ch-pill-3" id="pill3" onclick="UI.toggleChannel(3)"><div class="ch-dot"></div> CH3</div>
</div>

<!-- SCOPE CANVAS -->
<div id="scopeArea">
    <canvas id="scopeCanvas"></canvas>
    <div class="scope-overlay"       id="overlayLeft">CH1 | AC</div>
    <div class="scope-overlay-right" id="overlayRight">SR: 44.1kHz</div>
    <div id="trigMarkerTop" class="trig-marker trig-top">▶ T+</div>
    <div id="trigMarkerBot" class="trig-marker trig-bot">▶ T-</div>
    <div id="splash">
        <div class="splash-logo">LAB<br>SCOPE</div>
        <div class="splash-sub">MOBILE OSCILLOSCOPE · PRO</div>
        <div class="splash-specs">
            AUX / MIC INPUT · WEB AUDIO API<br>
            FFT + INFO OVERLAY · TRIGGER SYSTEM<br>
            SIMULATOR · OFFLINE CAPABLE · PWA
        </div>
        <button class="splash-btn" onclick="Audio.init()">▶ START PROBE</button>
    </div>
</div>

<!-- BODE ZONE STRIP -->
<div id="bodeZone">
    <div class="bode-zone-title">BODE — H(f) MAGNITUDE + PHASE</div>
    <svg id="bodeZoneSvg" class="bode-zone-svg" viewBox="0 0 340 70" preserveAspectRatio="none">
        <line x1="0" y1="17" x2="340" y2="17" stroke="rgba(0,229,255,0.08)"/>
        <line x1="0" y1="34" x2="340" y2="34" stroke="rgba(0,229,255,0.06)"/>
        <path id="bodeZoneMag"   d="" stroke="#00e5ff" stroke-width="1.5" fill="none"/>
        <path id="bodeZonePhase" d="" stroke="#ffb300"  stroke-width="1"   fill="none" opacity="0.7"/>
        <line id="bodeZoneHpf" x1="0"   y1="0" x2="0"   y2="70" stroke="rgba(255,23,68,0.4)" stroke-width="1" stroke-dasharray="3,3" style="display:none"/>
        <line id="bodeZoneLpf" x1="340" y1="0" x2="340" y2="70" stroke="rgba(255,23,68,0.4)" stroke-width="1" stroke-dasharray="3,3" style="display:none"/>
    </svg>
    <div class="bode-zone-legend">
        <span class="bz-mag">— magnitude</span>
        <span class="bz-phase">— phase</span>
        <span class="bz-markers">| -3dB markers</span>
        <span class="bz-result" id="bodeZoneResult">---</span>
    </div>
</div>

<!-- OSC CONTROLS -->
<div id="oscControls">
    <div class="osc-ctrl-row">
        <span class="osc-ctrl-label">ZOOM</span>
        <input type="range" id="zoomSlider" min="1" max="8" step="0.5" value="1" oninput="UI.updateZoom(this.value)">
        <span class="osc-ctrl-val" id="zoomVal">1.0x</span>
    </div>
    <div class="osc-ctrl-row">
        <span class="osc-ctrl-label">GAIN</span>
        <input type="range" id="gainSlider" min="1" max="10" step="0.5" value="3" oninput="UI.updateGain(this.value)">
        <span class="osc-ctrl-val" id="gainVal">3.0x</span>
    </div>
    <div class="osc-div-row">
        <div class="osc-div-group">
            <span class="osc-div-label">T/DIV</span>
            <button class="osc-div-btn" onclick="UI.adjustTimeDiv(-1)">◀</button>
            <span class="osc-div-val" id="timeDivVal">AUTO</span>
            <button class="osc-div-btn" onclick="UI.adjustTimeDiv(1)">▶</button>
        </div>
        <div class="osc-div-group">
            <span class="osc-div-label">V/DIV</span>
            <button class="osc-div-btn" onclick="UI.adjustVoltDiv(-1)">◀</button>
            <span class="osc-div-val" id="voltDivVal">AUTO</span>
            <button class="osc-div-btn" onclick="UI.adjustVoltDiv(1)">▶</button>
        </div>
    </div>
</div>

<!-- MIC BAR -->
<div id="micBar">
    <div class="mic-bar-dot" id="micDot" style="background:#00ff41"></div>
    <span class="mic-bar-label" id="micBarLabel">CH1 MIC ● live capture</span>
    <button class="mic-toggle-btn on" id="micToggleBtn" onclick="UI.toggleCH1Source()">∨ MIC</button>
</div>

<!-- SIM CHEVRON PANEL -->
<div id="simChevronWrap">
    <div id="simSourceRow">
        <button class="sim-src-btn active-synth" id="srcSynth" onclick="UI.setSimSource('synth')">SYNTH</button>
        <button class="sim-src-btn"              id="srcFile"  onclick="UI.setSimSource('file')">FILE</button>
    </div>
    <div class="sim-chevron-bar" onclick="UI.toggleSimChevron()">
        <span id="simChevronIcon">∧</span>
    </div>
    <div class="sim-chevron-content" id="simChevronContent">
        <div id="simSynthPanel" style="display:flex;flex-direction:column;gap:4px">
            <div class="wave-grid">
                <button class="wave-btn active" data-wave="sine"     onclick="UI.setSimWave('sine')">SINE</button>
                <button class="wave-btn"        data-wave="square"   onclick="UI.setSimWave('square')">SQ</button>
                <button class="wave-btn"        data-wave="triangle" onclick="UI.setSimWave('triangle')">TRI</button>
                <button class="wave-btn"        data-wave="sawtooth" onclick="UI.setSimWave('sawtooth')">SAW</button>
                <button class="wave-btn"        data-wave="ramp"     onclick="UI.setSimWave('ramp')">RAMP</button>
                <button class="wave-btn"        data-wave="pwm"      onclick="UI.setSimWave('pwm')">PWM</button>
                <button class="wave-btn"        data-wave="noise"    onclick="UI.setSimWave('noise')">NOISE</button>
                <button class="wave-btn"        data-wave="dc"       onclick="UI.setSimWave('dc')">DC</button>
            </div>
            <div class="osc-ctrl-row">
                <span class="osc-ctrl-label">FREQ</span>
                <input type="range" min="20" max="20000" step="10" value="1000" oninput="UI.setSimFreq(this.value)">
                <span class="osc-ctrl-val" id="simFreqVal">1000Hz</span>
            </div>
            <div class="osc-ctrl-row">
                <span class="osc-ctrl-label">AMP</span>
                <input type="range" min="0.05" max="1.0" step="0.05" value="0.8" oninput="UI.setSimAmp(this.value)">
                <span class="osc-ctrl-val" id="simAmpVal">0.80</span>
            </div>
            <div class="osc-ctrl-row">
                <span class="osc-ctrl-label">PHASE</span>
                <input type="range" min="0" max="360" step="5" value="0" oninput="UI.setSimPhase(this.value)">
                <span class="osc-ctrl-val" id="simPhaseVal">0°</span>
            </div>
            <div class="osc-ctrl-row" id="dutyRow" style="display:none">
                <span class="osc-ctrl-label">DUTY</span>
                <input type="range" min="5" max="95" step="5" value="50" oninput="UI.setSimDuty(this.value)">
                <span class="osc-ctrl-val" id="simDutyVal">50%</span>
            </div>
        </div>
        <div id="simFilePanel" style="display:none;flex-direction:column;gap:5px">
            <div class="sim-file-actions">
                <button class="sim-file-load-btn" onclick="UI.loadSimFileCH2()">+ LOAD FILE</button>
            </div>
            <div class="sim-file-info">
                <span class="sim-file-name-display empty" id="simFileName">no file loaded</span>
                <span class="sim-rec-timer idle"           id="simFileInfo">--</span>
            </div>
            <input type="file" id="simFilePicker" accept="audio/*" onchange="UI.onSimFileSelected(this)" style="display:none">
            <div class="osc-ctrl-row">
                <span class="osc-ctrl-label">GAIN</span>
                <input type="range" min="0.05" max="2.0" step="0.05" value="1.0" oninput="UI.setSimFileGain(this.value)">
                <span class="osc-ctrl-val" id="simFileGainVal">1.00x</span>
            </div>
        </div>
    </div>
    <div class="sim-collapsed-strip" id="simCollapsedStrip" style="display:none" onclick="UI.toggleSimChevron()">
        <div class="strip-line"></div>
        <span>∨ expand controls</span>
        <div class="strip-line"></div>
    </div>
</div>

<!-- BOTTOM CONTROLS -->
<div id="controls">
    <!-- OSC / FFT / INFO TABS -->
    <div id="mainBtns">
        <div class="btn-row">
            <button class="btn-primary"   id="pauseBtn"   onclick="UI.togglePause()" disabled>⏸ PAUSE</button>
            <button class="btn-secondary" id="triggerBtn" onclick="Trigger.toggle()">⚡ TRIG</button>
            <button class="btn-amber"                     onclick="UI.captureSnapshot()">📸 SNAP</button>
        </div>
        <div class="btn-row-2">
            <button class="btn-danger" style="width:100%" onclick="Audio.reset()">↺ RESET</button>
        </div>
    </div>
    <!-- SIM TAB -->
    <div id="simBtns" style="display:none">
        <div class="sim-header-row">
            <button class="btn-simset" onclick="UI.toggleSimSetMenu()">⚙ SIM SET</button>
        </div>
        <div class="sim-action-row">
            <button class="btn-secondary" id="simPlayBtn" onclick="UI.toggleSimPlay()">▶ PLAY</button>
            <button class="btn-amber"                     onclick="UI.captureSnapshot()">📸 SNAP</button>
            <button class="btn-danger"                    onclick="Audio.reset()">↺ RESET</button>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     MAIN SETTINGS MENU
══════════════════════════════════════════ -->
<div id="menuOverlay" onclick="UI.toggleMenu()"></div>
<div id="sideMenu">
    <div class="menu-header">
        <span class="menu-title">⚙ SETTINGS</span>
        <button class="menu-close" onclick="UI.toggleMenu()">✕</button>
    </div>

    <!-- MENU TABS -->
    <div id="menuTabs">
        <div class="mtab active" data-mtab="controls" onclick="UI.switchMenuTab('controls')">CONTROLS</div>
        <div class="mtab"        data-mtab="trigger"  onclick="UI.switchMenuTab('trigger')">TRIGGER</div>
        <div class="mtab"        data-mtab="calib"    onclick="UI.switchMenuTab('calib')">CALIBRATE</div>
        <div class="mtab"        data-mtab="theme"    onclick="UI.switchMenuTab('theme')">THEME</div>
        <div class="mtab"        data-mtab="manual"   onclick="UI.switchMenuTab('manual')">MANUAL</div>
        <div class="mtab"        data-mtab="build"    onclick="UI.switchMenuTab('build')">BUILD</div>
    </div>

    <!-- ── CONTROLS TAB ── -->
    <div class="mpanel active" id="mpanel-controls">
        <div class="mgroup">
            <div class="mgroup-title">DISPLAY</div>
            <div class="mrow">
                <span class="mlabel">SMOOTH</span>
                <input type="range" id="smoothSlider" min="0" max="0.95" step="0.05" value="0.6" oninput="UI.updateSmoothing(this.value)">
                <span class="mval" id="smoothVal">0.60</span>
            </div>
            <div class="mrow">
                <span class="mlabel">FFT SIZE</span>
                <div class="mrow-right">
                    <button class="mbtn" onclick="UI.adjustFFTSize(-1)">◀</button>
                    <span class="mval" id="fftSizeVal">4096</span>
                    <button class="mbtn" onclick="UI.adjustFFTSize(1)">▶</button>
                </div>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">TIMEBASE</div>
            <div class="mrow">
                <span class="mlabel">TIME/DIV</span>
                <div class="mrow-right">
                    <button class="mbtn" onclick="UI.adjustTimeDiv(-1)">◀</button>
                    <span class="mval" id="timeDivValMenu">AUTO</span>
                    <button class="mbtn" onclick="UI.adjustTimeDiv(1)">▶</button>
                </div>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">AMPLITUDE</div>
            <div class="mrow">
                <span class="mlabel">VOLT/DIV</span>
                <div class="mrow-right">
                    <button class="mbtn" onclick="UI.adjustVoltDiv(-1)">◀</button>
                    <span class="mval" id="voltDivValMenu">AUTO</span>
                    <button class="mbtn" onclick="UI.adjustVoltDiv(1)">▶</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── TRIGGER TAB ── -->
    <div class="mpanel" id="mpanel-trigger">
        <div class="mgroup">
            <div class="mgroup-title">MODE</div>
            <div class="mrow">
                <button class="mbtn-sel active" id="tmode-auto"   onclick="Trigger.setMode('auto')">AUTO</button>
                <button class="mbtn-sel"        id="tmode-normal" onclick="Trigger.setMode('normal')">NORMAL</button>
                <button class="mbtn-sel"        id="tmode-single" onclick="Trigger.setMode('single')">SINGLE</button>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">EDGE</div>
            <div class="mrow">
                <button class="mbtn-sel active" id="tedge-rising"  onclick="Trigger.setEdge('rising')">RISING ↑</button>
                <button class="mbtn-sel"        id="tedge-falling" onclick="Trigger.setEdge('falling')">FALLING ↓</button>
                <button class="mbtn-sel"        id="tedge-both"    onclick="Trigger.setEdge('both')">BOTH ↕</button>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">THRESHOLD</div>
            <div class="mrow">
                <span class="mlabel">UPPER</span>
                <input type="range" id="trigUpperSlider" min="-100" max="100" step="5" value="30" oninput="Trigger.updateUpper(this.value)">
                <span class="mval" id="trigUpperVal">+0.30V</span>
            </div>
            <div class="mrow">
                <span class="mlabel">LOWER</span>
                <input type="range" id="trigLowerSlider" min="-100" max="100" step="5" value="-30" oninput="Trigger.updateLower(this.value)">
                <span class="mval" id="trigLowerVal">-0.30V</span>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">STATUS</div>
            <div class="mrow">
                <span class="mlabel">STATE</span>
                <span class="mval" id="trigStatusVal" style="color:#006600">OFF</span>
            </div>
            <div class="mrow">
                <span class="mlabel">LAST FIRE</span>
                <span class="mval" id="trigLastFire">---</span>
            </div>
        </div>
        <div class="mrow-btn">
            <button class="mbtn-full" onclick="Trigger.forceArm()">↺ FORCE ARM</button>
        </div>
    </div>

    <!-- ── CALIBRATE TAB ── -->
    <div class="mpanel" id="mpanel-calib">
        <div class="mcalib-info">
            Connect a known reference signal (sine recommended). Enter the true frequency and voltage — Lab Scope measures the signal and calculates correction factors applied to all subsequent readings.
        </div>
        <div class="mgroup">
            <div class="mgroup-title">FREQUENCY CALIBRATION</div>
            <div class="mrow">
                <span class="mlabel">REF FREQ</span>
                <input type="text" class="minput" id="calibFreqInput" placeholder="1000" value="1000">
                <span style="font-size:0.7em;color:var(--text-mid)">Hz</span>
            </div>
            <div class="mrow">
                <button class="mbtn-full" onclick="Calibration.runFreq()">RUN CALIBRATION</button>
            </div>
            <div class="mrow">
                <span class="mlabel">RESULT</span>
                <span class="mval" id="calibFreqResult">1.000x</span>
            </div>
        </div>
        <div class="mgroup">
            <div class="mgroup-title">VOLTAGE CALIBRATION</div>
            <div class="mrow">
                <span class="mlabel">REF Vpp</span>
                <input type="text" class="minput" id="calibVppInput" placeholder="1.00" value="1.00">
                <span style="font-size:0.7em;color:var(--text-mid)">V</span>
            </div>
            <div class="mrow">
                <button class="mbtn-full" onclick="Calibration.runVpp()">RUN CALIBRATION</button>
            </div>
            <div class="mrow">
                <span class="mlabel">RESULT</span>
                <span class="mval" id="calibVppResult">1.000x</span>
            </div>
        </div>
        <div class="mrow-btn">
            <button class="mbtn-full btn-danger-full" onclick="Calibration.reset()">↺ RESET TO DEFAULT</button>
        </div>
    </div>

    <!-- ══════════════════════════════════════
         THEME TAB — channel waveform colors + canvas theme only
         No font/text-color settings
    ══════════════════════════════════════ -->
    <div class="mpanel" id="mpanel-theme">

        <!-- CANVAS THEME -->
        <div class="mgroup">
            <div class="mgroup-title">CANVAS THEME</div>
            <div class="mrow" style="gap:8px">
                <button class="theme-btn active" data-theme="dark"
                        style="flex:1;background:#020c0c;color:#00e5ff;border-color:#00e5ff"
                        onclick="UI.setTheme('dark')">⬛ DARK</button>
                <button class="theme-btn" data-theme="github"
                        style="flex:1;background:#ffffff;color:#1f2328;border-color:#d0d7de"
                        onclick="UI.setTheme('github')">☀️ LIGHT</button>
            </div>
        </div>

        <!-- CH1 COLOR -->
        <div class="mgroup">
            <div class="mgroup-title">CH1 WAVEFORM COLOR <span style="color:#e040fb;margin-left:6px">● purple</span></div>
            <div class="swatch-row">
                <div class="swatch-btn active" data-group="ch1" data-color="#e040fb" style="background:#e040fb" onclick="UI.setCH1Color('#e040fb')"></div>
                <div class="swatch-btn"        data-group="ch1" data-color="#ff1744" style="background:#ff1744" onclick="UI.setCH1Color('#ff1744')"></div>
                <div class="swatch-btn"        data-group="ch1" data-color="#00e5ff" style="background:#00e5ff" onclick="UI.setCH1Color('#00e5ff')"></div>
                <div class="swatch-btn"        data-group="ch1" data-color="#ffb300" style="background:#ffb300" onclick="UI.setCH1Color('#ffb300')"></div>
                <div class="swatch-btn"        data-group="ch1" data-color="#00ff41" style="background:#00ff41" onclick="UI.setCH1Color('#00ff41')"></div>
                <div class="swatch-btn"        data-group="ch1" data-color="#ff6d00" style="background:#ff6d00" onclick="UI.setCH1Color('#ff6d00')"></div>
            </div>
        </div>

        <!-- CH2 COLOR -->
        <div class="mgroup">
            <div class="mgroup-title">CH2 WAVEFORM COLOR <span style="color:#ff1744;margin-left:6px">● red</span></div>
            <div class="swatch-row">
                <div class="swatch-btn"        data-group="ch2" data-color="#e040fb" style="background:#e040fb" onclick="UI.setCH2Color('#e040fb')"></div>
                <div class="swatch-btn active" data-group="ch2" data-color="#ff1744" style="background:#ff1744" onclick="UI.setCH2Color('#ff1744')"></div>
                <div class="swatch-btn"        data-group="ch2" data-color="#00e5ff" style="background:#00e5ff" onclick="UI.setCH2Color('#00e5ff')"></div>
                <div class="swatch-btn"        data-group="ch2" data-color="#ffb300" style="background:#ffb300" onclick="UI.setCH2Color('#ffb300')"></div>
                <div class="swatch-btn"        data-group="ch2" data-color="#00ff41" style="background:#00ff41" onclick="UI.setCH2Color('#00ff41')"></div>
                <div class="swatch-btn"        data-group="ch2" data-color="#ff6d00" style="background:#ff6d00" onclick="UI.setCH2Color('#ff6d00')"></div>
            </div>
        </div>

        <!-- CH3 COLOR -->
        <div class="mgroup">
            <div class="mgroup-title">CH3 WAVEFORM COLOR <span style="color:#00e5ff;margin-left:6px">● cyan</span></div>
            <div class="swatch-row">
                <div class="swatch-btn"        data-group="ch3" data-color="#e040fb" style="background:#e040fb" onclick="UI.setCH3Color('#e040fb')"></div>
                <div class="swatch-btn"        data-group="ch3" data-color="#ff1744" style="background:#ff1744" onclick="UI.setCH3Color('#ff1744')"></div>
                <div class="swatch-btn active" data-group="ch3" data-color="#00e5ff" style="background:#00e5ff" onclick="UI.setCH3Color('#00e5ff')"></div>
                <div class="swatch-btn"        data-group="ch3" data-color="#ffb300" style="background:#ffb300" onclick="UI.setCH3Color('#ffb300')"></div>
